#!/bin/sh
# Adapted by https://github.com/0xalwayslucky/Sysd2v
# Set as file /etc/init.d/ and run `update-rc.d LumenForge defaults`
### BEGIN INIT INFO
# Provides: LumenForge
# Required-Start:	$local_fs $syslog
# Required-Stop:	$local_fs $syslog
# Default-Start:	2 3 4 5
# Default-Stop:		0 1 6
# Short-Description: Open source interface for iCUE LINK System Hub, Corsair AIOs and Hubs
### END INIT INFO

. /lib/lsb/init-functions
prog=LumenForge
PIDFILE=/var/run/$prog.pid
DESC="Open source interface for iCUE LINK System Hub, Corsair AIOs and Hubs"
WORKDIR=/opt/LumenForge
USER=lumenforge
GROUP=lumenforge
RESTART_MODE=always
RESTART_SEC=5

start() {
	log_daemon_msg "Starting $DESC" "$prog"
	cd /opt/LumenForge || {
		log_end_msg 1
		exit 1
	}
	start-stop-daemon --start --chuid "${USER}:${GROUP}" --chdir /opt/LumenForge --background --make-pidfile --pidfile $PIDFILE --exec /opt/LumenForge/LumenForge
	if [ $? -ne 0 ]; then
		log_end_msg 1
		exit 1
	fi
	if [ $? -eq 0 ]; then
		log_end_msg 0
	fi
}

stop() {
	log_daemon_msg "Stopping $DESC" "$prog"
	start-stop-daemon --stop --name $(basename /opt/LumenForge/LumenForge) --oknodo
	if [ $? -ne 0 ]; then
		log_end_msg 1
		exit 1
	fi
	if [ $? -eq 0 ]; then
		log_end_msg 0
	fi
}

status() {
	status_of_proc /opt/LumenForge/LumenForge "$prog"
}

reload() {
	log_daemon_msg "Reloading $DESC" "$prog"
	/bin/kill -s HUP "$( cat $PIDFILE )"
	if [ $? -ne 0 ]; then
		log_end_msg 1
		exit 1
	fi
	if [ $? -eq 0 ]; then
		log_end_msg 0
	fi
	exit 0
}

force_reload() {
	reload
	if [ $? -ne 0 ]; then
		restart
	fi
}

case "$1" in
	start)
		start
		;;
	stop)
		stop
		;;
	status)
		status
		;;
	force-reload)
		force_reload
		;;
	restart)
		stop
		sleep 2
		start
		;;
	reload)
		reload
		;;
	*)
		echo "Usage: $0 {start|stop|status|reload|force-reload|restart}"
		exit 2
esac
